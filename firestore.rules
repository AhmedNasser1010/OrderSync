rules_version = '2';

// =========================================================================
// FOOD-DELIVERY PLATFORM — FIRESTORE SECURITY RULES
//
// Apps served by this ruleset:
//   customer_app        -> customers place/track orders, leave reviews
//   orders_app          -> restaurant staff manage orders for 1 business
//   driver_app           -> couriers claim / deliver orders from marketplace
//   manager_app          -> restaurant managers view analytics and reports
//   onboarding_app       -> partners onboard & own one or more businesses
//
// Architecture:
//   orders/{orderId}     -> flat global collection, no subcollections
//   dailyReports/{id}    -> pre-computed daily analytics snapshots
// =========================================================================

service cloud.firestore {
  match /databases/{database}/documents {

    // =====================================================================
    // HELPER FUNCTIONS
    // =====================================================================

    function isSignedIn() {
      return request.auth != null;
    }

    function isOwner(userId) {
      return isSignedIn() && request.auth.uid == userId;
    }

    function resourceData() {
      return resource.data;
    }

    function incomingData() {
      return request.resource.data;
    }

    function hasUsersDoc() {
      return isSignedIn() && exists(/databases/$(database)/documents/users/$(request.auth.uid));
    }

    function hasCustomerDoc() {
      return isSignedIn() && exists(/databases/$(database)/documents/customers/$(request.auth.uid));
    }

    function getUsersDoc() {
      return get(/databases/$(database)/documents/users/$(request.auth.uid)).data;
    }

    function getManagerBusiness() {
      return get(/databases/$(database)/documents/businesses/$(managerAccessToken())).data;
    }

    function isCustomer() {
      return hasCustomerDoc();
    }

    function isManager() {
      return hasUsersDoc() && getUsersDoc().userInfo.role == 'BUSINESS_MANAGER';
    }

    function isPartner() {
      return hasUsersDoc() && getUsersDoc().userInfo.role == 'BUSINESSES_CREATOR';
    }

    function isRider() {
      return isSignedIn() && exists(/databases/$(database)/documents/drivers/$(request.auth.uid));
    }

    function managerAccessToken() {
      return hasUsersDoc() ? getUsersDoc().accessToken : null;
    }

    function isManagerOf(businessId) {
      return isManager() && managerAccessToken() == businessId;
    }

    function partnerOwnsToken(token) {
      return hasUsersDoc() && token in getUsersDoc().businesses;
    }

    function isPartnerOwner(partnerUid) {
      return isPartner() && isOwner(partnerUid);
    }

    // =====================================================================
    // /users/{userId}
    // =====================================================================
    match /users/{userId} {
      allow read: if isSignedIn();
      allow create: if isOwner(userId) || isPartnerOwner(incomingData().partnerUid);
      allow update: if isOwner(userId)
        && request.resource.data.diff(resource.data).affectedKeys()
            .hasOnly(['userInfo'])
        && request.resource.data.userInfo.role == resource.data.userInfo.role;
      allow update: if isPartner()
        && isOwner(userId)
        && request.resource.data.diff(resource.data).affectedKeys()
            .hasOnly(['data']);
      allow update, delete: if isPartnerOwner(resourceData().partnerUid);
    }

    // =====================================================================
    // /reviews/{reviewId}
    // =====================================================================
    match /reviews/{reviewId} {
      allow read: if true;
      allow create: if isCustomer();
      allow update, delete: if false;
    }

    // =====================================================================
    // /businesses/{busId}
    // =====================================================================
    match /businesses/{busId} {
      allow read: if true;
      allow create: if isPartnerOwner(incomingData().partnerUid);
      allow update: if isCustomer()
        && request.resource.data.diff(resource.data)
            .affectedKeys()
            .hasOnly(['reviewSummary']);
      allow update: if isManagerOf(busId);
      allow update, delete: if isPartnerOwner(resourceData().partnerUid);
    }

    // =====================================================================
    // /menus/{menuId}
    // =====================================================================
    match /menus/{menuId} {
      allow read: if true;
      allow update, delete: if isManagerOf(menuId);
      allow create: if isPartnerOwner(incomingData().partnerUid);
      allow update, delete: if isPartner() &&
        partnerOwnsToken(resourceData().accessToken);
    }

    // =====================================================================
    // /customers/{userId}
    // =====================================================================
    match /customers/{userId} {
      allow read: if isOwner(userId);
      allow create: if isOwner(userId)
        && incomingData().userInfo.role == 'CUSTOMER';
      allow update: if isCustomer() && isOwner(userId);
      allow delete: if false;
    }

    // =====================================================================
    // /drivers/{driverId}
    // =====================================================================
    match /drivers/{driverId} {
      allow read: if isOwner(driverId);
      allow read: if isCustomer() &&
        resourceData().trackingCustomerIds != null &&
        request.auth.uid in resourceData().trackingCustomerIds;
      allow read: if isManagerOf(resourceData().accessToken);
      allow read: if isPartnerOwner(resourceData().partnerUid);
      allow create: if isPartnerOwner(incomingData().partnerUid);
      allow update: if isOwner(driverId);
      allow update: if isManagerOf(resourceData().accessToken);
      allow update: if isPartner() && resourceData().partnerUid == request.auth.uid;
      allow delete: if isManagerOf(resourceData().accessToken);
      allow delete: if isPartner() && resourceData().partnerUid == request.auth.uid;
    }

    // =====================================================================
    // /orders/{orderId}
    //
    // Flat global collection. No subcollections.
    // Every order document contains:
    //   - accessToken, customer.uid, assignment.driverUid
    //   - status.current, status.history[]
    //   - timeline, pricing, finance, reconciliation
    // =====================================================================
    match /orders/{orderId} {

      // --- READ permissions ---

      // Customers can read orders they placed.
      allow read: if isCustomer()
        && resourceData().customer.uid == request.auth.uid;

      // Managers can read orders for their business.
      allow read: if isManager()
        && resourceData().businessId == managerAccessToken();

      // Partners can read orders for their businesses.
      allow read: if isPartner()
        && resourceData().businessId in partnerBusinessIds();

      // Drivers can read READY orders (marketplace browsing).
      allow read: if isRider()
        && resourceData().status.current == 'READY';

      // Drivers can read orders assigned to them.
      allow read: if isRider()
        && resourceData().assignment != null
        && resourceData().assignment.driverUid == request.auth.uid;

      // --- CREATE permissions ---

      // Customers can create orders they placed.
      allow create: if isCustomer()
        && incomingData().customer.uid == request.auth.uid
        && incomingData().status.current == 'RECEIVED';

      // Customers can initialize the orders root document (lazily on first order).
      allow create: if isCustomer()
        && incomingData().accessToken is string;

      // --- UPDATE permissions ---

      // Customers can cancel their own order (only from RECEIVED status).
      allow update: if isCustomer()
        && resourceData().customer.uid == request.auth.uid
        && resourceData().status.current == 'RECEIVED'
        && incomingData().status.current == 'CANCELED'
        && incomingData().diff(resourceData()).affectedKeys()
            .hasOnly(['status', 'timeline', 'updatedAt']);

      // Managers can update status and timeline for their business orders.
      allow update: if isManager()
        && resourceData().businessId == managerAccessToken()
        && incomingData().diff(resourceData()).affectedKeys()
            .hasOnly(['status', 'timeline', 'updatedAt']);

      // Drivers can claim a READY order (RESERVED transition).
      // The driver must not already own another active order.
      allow update: if isRider()
        && resourceData().status.current == 'READY'
        && incomingData().status.current == 'RESERVED'
        && incomingData().assignment.driverUid == request.auth.uid
        && incomingData().diff(resourceData()).affectedKeys()
            .hasOnly(['status', 'timeline', 'assignment', 'updatedAt']);

      // Drivers can update their assigned orders (PICKED_UP, ON_ROUTE, DELIVERED, CANCELED).
      allow update: if isRider()
        && resourceData().assignment.driverUid == request.auth.uid
        && incomingData().diff(resourceData()).affectedKeys()
            .hasOnly(['status', 'timeline', 'updatedAt']);

      // Customers can submit feedback on delivered orders.
      allow update: if isCustomer()
        && resourceData().customer.uid == request.auth.uid
        && resourceData().status.current == 'DELIVERED'
        && incomingData().status.current == 'GIVEN_FEEDBACK'
        && incomingData().diff(resourceData()).affectedKeys()
            .hasOnly(['status', 'timeline', 'customerFeedback', 'updatedAt']);

      // Partners can update reconciliation fields.
      allow update: if isPartner()
        && resourceData().businessId in partnerBusinessIds()
        && incomingData().diff(resourceData()).affectedKeys()
            .hasOnly(['reconciliation', 'updatedAt']);
    }

    // =====================================================================
    // /dailyReports/{reportId}
    //
    // Pre-computed daily analytics snapshots written by orders_app
    // when the restaurant closes the day.
    // Document ID format: {businessId}_{yyyy-MM-dd}
    // =====================================================================
    match /dailyReports/{reportId} {
      allow read: if isSignedIn();
      allow write: if isSignedIn();
    }

    // =====================================================================
    // Helper: returns list of business IDs owned by the authenticated partner
    // Used in /orders/{orderId} rules for partner read and reconciliation access.
    // =====================================================================
    function partnerBusinessIds() {
      return hasUsersDoc() ? getUsersDoc().data.businesses : [];
    }
  }
}
